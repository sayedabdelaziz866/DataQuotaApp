<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/txtLastCheck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#FFAA00"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/txtBootReceiverStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#FF5555"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/txtVpnStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#FF5555"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/txtCurrentWifi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/txtHomeNetwork"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnRegisterNetwork"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="سجّل الشبكة الحالية كشبكة البيت"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"
            android:text="مهم: عشان المراقبة تشتغل وإنت مش فاتح التطبيق، لازم صلاحية الموقع تكون على &quot;اسمح طول الوقت&quot; مش بس أثناء الاستخدام" />

        <Button
            android:id="@+id/btnOpenLocationSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="افتح إعدادات صلاحية الموقع"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnDisableBatteryOptimization"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="استثناء التطبيق من توفير البطارية"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/inputManualBssid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="أضف BSSID يدوي (مثلاً bc:96:80:ad:6b:42)"
            android:inputType="textNoSuggestions" />

        <Button
            android:id="@+id/btnAddManualBssid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="إضافة الـ BSSID ده لشبكة البيت"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/txtUsage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/inputLimitGb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="عدد الجيجابايت (مثلاً 20)"
            android:inputType="numberDecimal" />

        <Button
            android:id="@+id/btnSaveLimit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="حفظ الحد"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnToggleMonitoring"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="بدء المراقبة"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnResetUsage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="تصفير الاستهلاك"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/txtDeviceOwnerStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnApplyUninstallProtection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="فعّل الحماية من الحذف"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnEnableAlwaysOnVpn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="فعّل إذن VPN الدائم (يحل مشكلة الريستارت)"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="الاستهلاك اليومي (آخر 7 أيام)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.dataquota.app.BarChartView
            android:id="@+id/dailyChart"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="الأكثر استهلاكًا للنت"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnOpenUsageAccessSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="افتح صلاحية Usage Access"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/topAppsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>
